      "target": "",
      "status": "untranslated",
      "paragraph_id": 18,
      "document_position": 18,
      "notes": "",
      "modified": false,
      "created_at": "2025-10-12T16:41:13.101212",
      "modified_at": "2025-10-12T16:41:13.101212",
      "is_table_cell": false,
      "table_info": null,
      "style": "Normal"
    },
    {
      "id": 20,
      "source": "And since all finishes in the product brand also apply here, the TE 440 3D door hinge blends seamlessly into the interior design of the building.",
