dl:cxt id="9"/></sdl:cxts><trans-unit id="5616ed0e-fff9-4b2a-bfef-7949d8411334"><source>Pagano had made 250 appearances in Italian Serie B, including 2 in the playoffs in 2008–09 Serie B.</source><seg-source>Pagano had made 250 appearances in Italian Serie B, including 2 in the playoffs in 2008–09 Serie B.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="11"/><sdl:cxt id="6"/><sdl:node id="4"/></sdl:cxts><trans-unit id="97e9442f-5f83-45a6-9441-adf3a9617248"><source>Personal information</source><seg-source>Personal information</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="12"/><sdl:cxt id="13"/><sdl:cxt id="14"/><sdl:cxt id="15"/><sdl:node id="7"/></sdl:cxts><trans-unit id="ec38d53c-1d48-42c8-8659-fa2c43a78b6e"><source>Date of birth</source><seg-source>Date of birth</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="16"/><sdl:cxt id="13"/><sdl:cxt id="14"/><sdl:cxt id="15"/><sdl:node id="8"/></sdl:cxts><trans-unit id="11306f2b-0c37-4245-b875-668898f3d79f"><source>29 January 1983 (age 42)</source><seg-source>29 January 1983 (age 42)</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="17"/><sdl:cxt id="13"/><sdl:cxt id="14"/><sdl:cxt id="15"/><sdl:node id="10"/></sdl:cxts><trans-unit id="f7272d7b-60bd-4c29-a4c3-2d79551a17f9"><source>Place of birth</source><seg-source>Place of birth</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="18"/><sdl:cxt id="13"/><sdl:cxt id="14"/><sdl:cxt id="15"/><sdl:node id="11"/></sdl:cxts><trans-unit id="95bfb357-09f5-425a-92db-635e463c77f9"><source><g id="33" xid="281126d5-e92b-4e89-a4fb-393ddb7a9809">Naples</g>, Italy</source><seg-source><g id="33" xid="281126d5-e92b-4e89-a4fb-393ddb7a9809">Naples</g>, Italy</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="19"/></sdl:cxts><trans-unit id="281126d5-e92b-4e89-a4fb-393ddb7a9809"><source>https://en.wikipedia.org/wiki/Naples</source><seg-source>https://en.wikipedia.org/wiki/Naples</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="20"/><sdl:cxt id="13"/><sdl:cxt id="14"/><sdl:cxt id="15"/><sdl:node id="13"/></sdl:cxts><trans-unit id="491cd506-400c-4e6b-9a1b-447b6a12be9f"><source>Height</source><seg-source>Height</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="21"/><sdl:cxt id="13"/><sdl:cxt id="14"/><sdl:cxt id="15"/><sdl:node id="14"/></sdl:cxts><trans-unit id="891d2ff3-dc43-46a4-afd2-a7e15a8a96e2"><source>1.80 m (5 ft 11 in)</source><seg-source>1.80 m (5 ft 11 in)</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="22"/><sdl:cxt id="6"/><sdl:node id="15"/></sdl:cxts><trans-unit id="de4dc83a-35d1-4bf8-862a-6b220854367c"><source>Career</source><seg-source>Career</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="23"/><sdl:cxt id="9"/></sdl:cxts><trans-unit id="206957cc-31c8-49f9-96d7-a4e9980db829"><source>Pagano started his career at <g id="52" xid="016d24fd-251c-4cbb-90ce-78ad466e40ca 226853aa-3058-4ea9-9d43-ea537e4de64c">Atalanta</g>. He made his Serie A debut on 17 June 2001 against <g id="59" xid="9418a1a0-5dbf-4776-b4e7-70d9b14cff23 83808dd4-ac02-4e7c-bb17-cd75791db57d">Juventus FC</g> He played a few more Serie A games for Atalanta in October 2003, after he was returned from loan to <g id="66" xid="5cfef2ec-113d-49ea-ae71-910567fcb72a a7c8ead9-d1d8-4c55-b416-4d064213d28e">Lumezzane</g> of the third division in <g id="73" xid="feb549ce-cc97-48b7-b737-9ace3d973efd 2cc53250-4f52-494b-ad48-1f13dd673a04">2002–03 Serie C1</g>.</source><seg-source>Pagano started his career at <g id="52" xid="016d24fd-251c-4cbb-90ce-78ad466e40ca 226853aa-3058-4ea9-9d43-ea537e4de64c">Atalanta</g>. He made his Serie A debut on 17 June 2001 against <g id="59" xid="9418a1a0-5dbf-4776-b4e7-70d9b14cff23 83808dd4-ac02-4e7c-bb17-cd75791db57d">Juventus FC</g> He played a few more Serie A games for Atalanta in October 2003, after he was returned from loan to <g id="66" xid="5cfef2ec-113d-49ea-ae71-910567fcb72a a7c8ead9-d1d8-4c55-b416-4d064213d28e">Lumezzane</g> of the third division in <g id="73" xid="feb549ce-cc97-48b7-b737-9ace3d973efd 2cc53250-4f52-494b-ad48-1f13dd673a04">2002–03 Serie C1</g>.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="24"/></sdl:cxts><trans-unit id="016d24fd-251c-4cbb-90ce-78ad466e40ca"><source>https://en.wikipedia.org/wiki/Atalanta_B.C.</source><seg-source>https://en.wikipedia.org/wiki/Atalanta_B.C.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="25"/></sdl:cxts><trans-unit id="226853aa-3058-4ea9-9d43-ea537e4de64c"><source>Atalanta B.C.</source><seg-source>Atalanta B.C.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="26"/></sdl:cxts><trans-unit id="9418a1a0-5dbf-4776-b4e7-70d9b14cff23"><source>https://en.wikipedia.org/wiki/Juventus_FC</source><seg-source>https://en.wikipedia.org/wiki/Juventus_FC</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="27"/></sdl:cxts><trans-unit id="83808dd4-ac02-4e7c-bb17-cd75791db57d"><source>Juventus FC</source><seg-source>Juventus FC</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="28"/></sdl:cxts><trans-unit id="5cfef2ec-113d-49ea-ae71-910567fcb72a"><source>https://en.wikipedia.org/wiki/F.C._Lumezzane_V.G.Z._A.S.D.</source><seg-source>https://en.wikipedia.org/wiki/F.C._Lumezzane_V.G.Z._A.S.D.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="29"/></sdl:cxts><trans-unit id="a7c8ead9-d1d8-4c55-b416-4d064213d28e"><source>F.C. Lumezzane V.G.Z. A.S.D.</source><seg-source>F.C. Lumezzane V.G.Z. A.S.D.</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl:cxt id="30"/></sdl:cxts><trans-unit id="feb549ce-cc97-48b7-b737-9ace3d973efd"><source>https://en.wikipedia.org/wiki/2002%E2%80%9303_Serie_C1</source><seg-source>https://en.wikipedia.org/wiki/2002%E2%80%9303_Serie_C1</seg-source><target/></trans-unit></group><group><sdl:cxts><sdl: